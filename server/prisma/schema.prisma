// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id        String   @id
  timestamp DateTime
  type      String
  desc      String
  source    String
}

model Entity {
  id          String   @id
  type        String
  label       String
  state       String
  relations   String   // JSON array string
  riskScore   Float
  performance Float
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String @default("USER")
}
